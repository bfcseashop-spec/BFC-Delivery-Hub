# BFC Fast Delivery — Environment Variables Reference
# ====================================================
# In Replit, these are managed via the Secrets panel (not this file).
# This file documents every variable the project needs.

# ── PostgreSQL Database ──────────────────────────────────────────────────────
# Full connection string for the PostgreSQL database.
# Replit provides this automatically when you attach a PostgreSQL database.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Individual PG connection params (Replit sets these alongside DATABASE_URL)
PGHOST=host
PGPORT=5432
PGDATABASE=dbname
PGUSER=user
PGPASSWORD=password

# ── Session Security ─────────────────────────────────────────────────────────
# A long, random secret used to sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# ── API Server ───────────────────────────────────────────────────────────────
# Port the Express API server listens on (set automatically in artifact.toml)
PORT=8080

# Set to "production" in deployed environments
NODE_ENV=development

# ── Frontend (Vite Build) ────────────────────────────────────────────────────
# Dev-server / build port for the React frontend
# PORT=22214 (set via artifact.toml services.env)

# Base path prefix for all routes and assets.
# Must match the artifact's previewPath in artifact.toml.
# BASE_PATH=/ (set via artifact.toml services.env)

# ── Replit Runtime (auto-injected, do not set manually) ──────────────────────
# REPL_ID         — Replit workspace identifier
# REPLIT_DOMAINS  — Comma-separated list of allowed domains
# REPLIT_DEV_DOMAIN — Dev domain for the workspace
